<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/disclaimer_footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel_glass"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/disclaimer_enter_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="@string/disclaimer_enter_button"
            android:textSize="15sp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/disclaimer_button_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.65"
            android:gravity="center"
            android:paddingTop="8dp"
            android:text="@string/disclaimer_button_hint"
            android:textColor="?attr/colorOnBackground"
            android:textSize="11sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/disclaimer_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/disclaimer_footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel_glass"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/disclaimer_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/disclaimer_title"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/disclaimer_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.72"
                android:paddingTop="6dp"
                android:text="@string/disclaimer_subtitle"
                android:textColor="?attr/colorOnBackground"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_stat_chip"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/disclaimer_torrent_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/disclaimer_torrent_title"
                    android:textColor="@color/torrent_highlight_color"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/disclaimer_torrent_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/disclaimer_torrent_message"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/disclaimer_privacy_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/disclaimer_privacy_title"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/disclaimer_privacy_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/disclaimer_privacy_message"
                android:textColor="?attr/colorOnBackground"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/disclaimer_privacy_link_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/disclaimer_privacy_link"
                android:textSize="12sp"
                app:cornerRadius="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/disclaimer_agree_torrent_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/disclaimer_agree_torrent"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/disclaimer_agree_privacy_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/disclaimer_agree_privacy"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
