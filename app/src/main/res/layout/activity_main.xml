<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_gradient"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/top_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_toolbar_glass"
            android:elevation="0dp"
            android:minHeight="?attr/actionBarSize"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:title="@string/app_name"
            app:titleTextColor="@color/text_primary" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/main_scroll_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:isScrollContainer="true"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/main_content_padding">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_panel_glass"
                        android:orientation="vertical"
                        android:padding="@dimen/package_card_inner_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/package_selector_title"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/selected_package_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/selected_package_icon"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_package_icon_chip"
                                android:contentDescription="@string/package_selector_title"
                                android:padding="8dp"
                                android:src="@drawable/ic_pkg_default" />

                            <TextView
                                android:id="@+id/selected_package_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="@string/package_selected_none"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <HorizontalScrollView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:scrollbars="none">

                                <LinearLayout
                                    android:id="@+id/package_icon_container"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal" />
                            </HorizontalScrollView>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/custom_sni_button"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:layout_marginStart="8dp"
                                android:contentDescription="@string/package_custom_sni"
                                app:backgroundTint="@color/card_selected_background"
                                app:cornerRadius="12dp"
                                app:icon="@drawable/ic_pkg_plus"
                                app:iconTint="@color/text_primary"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/subscription_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/loading_packages"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/parsed_packages_debug"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/parsed_packages_none"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/last_sync_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/last_sync_never"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_stat_chip"
                                android:minHeight="@dimen/stats_chip_min_height"
                                android:orientation="vertical"
                                android:padding="@dimen/stats_chip_padding">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/remaining_data_label"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/remaining_data_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/subscription_loading_value"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_stat_chip"
                                android:minHeight="@dimen/stats_chip_min_height"
                                android:orientation="vertical"
                                android:padding="@dimen/stats_chip_padding">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/expiry_date_label"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/expiry_date_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/subscription_loading_value"
                                    android:textColor="@color/text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_panel_glass"
                    android:paddingTop="14dp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="@dimen/power_ring_size"
                        android:layout_height="@dimen/power_ring_size"
                        android:layout_gravity="center_horizontal">

                        <View
                            android:layout_width="@dimen/power_ring_size"
                            android:layout_height="@dimen/power_ring_size"
                            android:background="@drawable/bg_connect_ring" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_connection"
                            android:layout_width="@dimen/power_button_size"
                            android:layout_height="@dimen/power_button_size"
                            android:layout_gravity="center"
                            android:insetBottom="0dp"
                            android:insetTop="0dp"
                            android:text="@string/connect"
                            android:textAllCaps="false"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/connect_disconnected"
                            app:cornerRadius="@dimen/power_button_radius"
                            app:strokeColor="@color/connect_ring_stroke"
                            app:strokeWidth="2dp" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/connection_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="@string/not_connected"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ping"
                        android:layout_width="132dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="@string/ping"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/card_selected_background"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_ping_small"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="16dp"
                        app:iconTint="@color/text_primary" />

                    <TextView
                        android:id="@+id/ping_ip_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="@string/ping_ip_idle"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="296dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/card_background"
        app:headerLayout="@layout/nav_header"
        app:itemBackground="@drawable/nav_item_background"
        app:itemHorizontalPadding="18dp"
        app:itemIconPadding="16dp"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/nav_item_icon_tint"
        app:itemTextAppearance="@style/TextAppearance.BypassX.DrawerItem"
        app:itemTextColor="@color/nav_item_text_color"
        app:menu="@menu/drawer_menu" />

    <LinearLayout
        android:id="@+id/proxy_tethering_drawer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/card_background"
        android:orientation="vertical"
        android:padding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="148dp"
            android:background="@drawable/bg_nav_header"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/menu_settings"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:fontFamily="sans-serif-thin"
                android:alpha="0.9"
                android:textStyle="normal" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Split Tunnel Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/split_tunnel_title"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="normal"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/split_tunnel_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/split_tunnel_enable"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/split_tunnel_description"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:layout_height="228dp"
                    android:scrollbars="vertical">

                    <LinearLayout
                        android:id="@+id/split_tunnel_apps_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>

                <TextView
                    android:id="@+id/split_tunnel_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/split_tunnel_no_apps"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/panel_stroke" />

                <!-- Proxy Tethering Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/proxy_tethering_title"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="normal"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/proxy_tethering_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/proxy_tethering_enable"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/proxy_hotspot_settings_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/proxy_tethering_open_hotspot_settings"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/card_selected_background"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/proxy_guide_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/proxy_tethering_show_guide"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/card_selected_background"
                    app:cornerRadius="12dp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp"
                    android:scrollbars="vertical">

                    <TextView
                        android:id="@+id/proxy_log_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/proxy_tethering_log_header"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp"
                        android:breakStrategy="high_quality" />
                </ScrollView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>