<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#081020"
                android:centerColor="#0B162A"
                android:endColor="#101D33" />
        </shape>
    </item>
    <item android:top="-120dp" android:left="-90dp">
        <shape android:shape="oval">
            <size android:width="320dp" android:height="320dp" />
            <solid android:color="@color/glow_blue" />
        </shape>
    </item>
    <item android:right="-120dp" android:bottom="-130dp">
        <shape android:shape="oval">
            <size android:width="360dp" android:height="360dp" />
            <solid android:color="@color/glow_teal" />
        </shape>
    </item>
</layer-list>
